<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.r2u.anibus.AnibusController">
    <children>

        <!-- Navigation Bar -->
        <HBox alignment="CENTER" styleClass="nav-bar">
            <children>
                <Label text="Anibus" styleClass="nav-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="About" onAction="#onAboutClick" styleClass="nav-link" />
            </children>
        </HBox>

        <!-- Status Bar -->
        <HBox alignment="CENTER_LEFT" styleClass="status-bar" spacing="8">
            <children>
                <Circle fx:id="networkDot" radius="5" fill="#8E8E93" styleClass="network-dot" />
                <Label fx:id="statusLabel" text="Ready" styleClass="status-label" />
            </children>
        </HBox>

        <!-- Tab Pane -->
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS"
                 styleClass="anibus-tab-pane">
            <tabs>
                <Tab text="Port Scanner">
                    <ScrollPane fitToWidth="true">
                        <fx:include source="port-scanner-tab.fxml" fx:id="portScanner" />
                    </ScrollPane>
                </Tab>
                <Tab text="JavaScript Analysis">
                    <ScrollPane fitToWidth="true">
                        <fx:include source="js-analysis-tab.fxml" fx:id="jsAnalysis" />
                    </ScrollPane>
                </Tab>
                <Tab text="SQL Injection">
                    <ScrollPane fitToWidth="true">
                        <fx:include source="sql-injection-tab.fxml" fx:id="sqlInjection" />
                    </ScrollPane>
                </Tab>
            </tabs>
        </TabPane>

    </children>
</VBox>
