<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.r2u.anibus.SqlInjectionController"
      spacing="10" styleClass="content-area">
    <padding><Insets top="10" right="10" bottom="10" left="10" /></padding>
    <children>

        <!-- SQL Injection Testing Card -->
        <VBox spacing="10" styleClass="card">
            <children>
                <Label text="SQL Injection Testing" styleClass="title-label" />

                <!-- URL input -->
                <HBox spacing="12" alignment="BOTTOM_LEFT">
                    <children>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="TARGET URL" styleClass="subtitle-label" />
                                <TextField fx:id="sqlTargetUrlField"
                                           promptText="https://example.com" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Actions -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <children>
                        <Button fx:id="sqlRunButton" onAction="#onSqlRunButtonClick"
                                text="Run Injection Test" styleClass="scan-button" />
                        <Button fx:id="sqlStopButton" onAction="#onSqlStopButtonClick"
                                text="Stop" disable="true" styleClass="stop-button" />
                        <Region HBox.hgrow="ALWAYS" />
                        <ProgressBar fx:id="sqlProgressBar" visible="false"
                                     prefWidth="140" prefHeight="6" />
                    </children>
                </HBox>

                <!-- Results Summary -->
                <VBox fx:id="sqlResultsCard" spacing="10" visible="false">
                    <children>
                        <Label text="Test Results" styleClass="section-title" />
                        <HBox spacing="24">
                            <children>
                                <VBox spacing="4" styleClass="info-item">
                                    <children>
                                        <Label text="ENDPOINTS TESTED" styleClass="info-key" />
                                        <Label fx:id="sqlEndpointsLabel" text="0" styleClass="info-value" />
                                    </children>
                                </VBox>
                                <VBox spacing="4" styleClass="info-item">
                                    <children>
                                        <Label text="VULNERABLE" styleClass="info-key" />
                                        <Label fx:id="sqlVulnerableLabel" text="0" styleClass="info-value" />
                                    </children>
                                </VBox>
                                <VBox spacing="4" styleClass="info-item">
                                    <children>
                                        <Label text="PAYLOADS FIRED" styleClass="info-key" />
                                        <Label fx:id="sqlPayloadsLabel" text="0" styleClass="info-value" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>

        <!-- Console Tabs: switch between Live Log and Injection Output -->
        <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" styleClass="anibus-tab-pane">
            <tabs>
                <Tab text="Live Log">
                    <content>
                        <VBox spacing="8" styleClass="card">
                            <children>
                                <Label text="Live Log" styleClass="section-title" />
                                <TextArea fx:id="liveLogArea"
                                    editable="false" wrapText="false"
                                    styleClass="console-view"
                                    VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>
                    </content>
                </Tab>

                <Tab text="Injection Output">
                    <content>
                        <VBox spacing="14" styleClass="card">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <children>
                                        <Label text="Injection Output" styleClass="section-title" />
                                        <Label fx:id="sqlStatusLabel" text="" styleClass="counter-label" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="sqlExportButton" text="Export"
                                                onAction="#onSqlExportClick"
                                                styleClass="secondary-button" disable="true" />
                                        <Button fx:id="sqlClearButton" text="Clear"
                                                onAction="#onSqlClearClick"
                                                styleClass="secondary-button" disable="true" />
                                    </children>
                                </HBox>

                                <TextArea fx:id="sqlConsoleArea"
                                    editable="false" wrapText="false"
                                    styleClass="console-view"
                                    VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>

    </children>
</VBox>
